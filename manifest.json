{
  "manifest_version": 3,
  "key": "",
  "name": "AI Site Collector",
  "version": "3.5.0",
  "description": "Automatically detect and save AI and useful websites to Google Drive with descriptions and features",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "activeTab",
    "identity",
    "identity.email",
    "notifications"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "AI Site Collector"
  },
  "options_page": "options/index.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_idle"
    }
  ],
  "oauth2": {
    "client_id": "1089864593616-7g3fvdj1l30deceha1q1prdidi7uko14.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon-16.png",
        "icons/icon-48.png",
        "icons/icon-128.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
